# Keep large non-yeast genome source datasets local.
genome_data/aspergillus/
genome_data/c_elegans/
genome_data/candida/
genome_data/cryptococcus/
genome_data/neurospora/
genome_data/s_pombe/
genome_data/salmonella/
# Legacy flat layout (pre full/train/test split).
genome_data/*_data/

# Local OS and Python-generated files.
.DS_Store
**/.DS_Store
__pycache__/
**/__pycache__/
*.pyc

# Local CNN training artifacts (keep test scores, ignore train scores).
genome_data/fission_yeasts/**/train/*.tsv
src/model/cnn/trained_models/*
!src/model/cnn/trained_models/.gitkeep
src/model/CNN/trained_models/*
!src/model/CNN/trained_models/.gitkeep
src/model/training_pipeline/trained_models/*
!src/model/training_pipeline/trained_models/.gitkeep
src/model/cnn/*_scores.tsv

# Generated validation outputs can exceed GitHub's file size limit.
validation/results/fission_yeasts_cnn_s_pombe.txt
