{
    "name": "fission_yeasts",
    "description": "Combined Schizosaccharomyces profile: S. pombe, S. japonicus, S. octosporus, and S. cryophilus",

    "dataset": {
        "species": [
            {
                "name": "s_pombe",
                "source_fasta": "genome_data/fission_yeasts/s_pombe/full/s_pombe_full.fna",
                "source_gff":   "genome_data/fission_yeasts/s_pombe/full/s_pombe_full.gff",
                "train_fasta":  "genome_data/fission_yeasts/s_pombe/train/s_pombe_train.fna",
                "train_gff":    "genome_data/fission_yeasts/s_pombe/train/s_pombe_train.gff",
                "test_fasta":   "genome_data/fission_yeasts/s_pombe/test/s_pombe_test.fna",
                "test_gff":     "genome_data/fission_yeasts/s_pombe/test/s_pombe_test.gff",
                "test_chromosomes": ["NC_003424.3"],
                "excluded_chromosomes": ["NC_001326.1"]
            },
            {
                "name": "s_japonicus",
                "source_fasta": "genome_data/fission_yeasts/s_japonicus/full/s_japonicus_full.fna",
                "source_gff":   "genome_data/fission_yeasts/s_japonicus/full/s_japonicus_full.gff",
                "train_fasta":  "genome_data/fission_yeasts/s_japonicus/train/s_japonicus_train.fna",
                "train_gff":    "genome_data/fission_yeasts/s_japonicus/train/s_japonicus_train.gff",
                "test_fasta":   "genome_data/fission_yeasts/s_japonicus/test/s_japonicus_test.fna",
                "test_gff":     "genome_data/fission_yeasts/s_japonicus/test/s_japonicus_test.gff",
                "test_chromosomes": ["KE651166.1"],
                "excluded_chromosomes": []
            },
            {
                "name": "s_octosporus",
                "source_fasta": "genome_data/fission_yeasts/s_octosporus/full/s_octosporus_full.fna",
                "source_gff":   "genome_data/fission_yeasts/s_octosporus/full/s_octosporus_full.gff",
                "train_fasta":  "genome_data/fission_yeasts/s_octosporus/train/s_octosporus_train.fna",
                "train_gff":    "genome_data/fission_yeasts/s_octosporus/train/s_octosporus_train.gff",
                "test_fasta":   "genome_data/fission_yeasts/s_octosporus/test/s_octosporus_test.fna",
                "test_gff":     "genome_data/fission_yeasts/s_octosporus/test/s_octosporus_test.gff",
                "test_chromosomes": ["KE503206.1"],
                "excluded_chromosomes": []
            },
            {
                "name": "s_cryophilus",
                "source_fasta": "genome_data/fission_yeasts/s_cryophilus/full/s_cryophilus_full.fna",
                "source_gff":   "genome_data/fission_yeasts/s_cryophilus/full/s_cryophilus_full.gff",
                "train_fasta":  "genome_data/fission_yeasts/s_cryophilus/train/s_cryophilus_train.fna",
                "train_gff":    "genome_data/fission_yeasts/s_cryophilus/train/s_cryophilus_train.gff",
                "test_fasta":   "genome_data/fission_yeasts/s_cryophilus/test/s_cryophilus_test.fna",
                "test_gff":     "genome_data/fission_yeasts/s_cryophilus/test/s_cryophilus_test.gff",
                "test_chromosomes": ["KE546988.1"],
                "excluded_chromosomes": []
            }
        ]
    },

    "splice_cnn": {
        "model": "src/model/cnn/splice/trained_models/fission_yeasts_splice_cnn.pt",
        "donor_scale": 1.0,
        "donor_bias": 0.0,
        "acceptor_scale": 1.0,
        "acceptor_bias": 0.0,
        "train_scores": [
            "genome_data/fission_yeasts/s_pombe/train/s_pombe_splice_cnn_scores.tsv",
            "genome_data/fission_yeasts/s_japonicus/train/s_japonicus_splice_cnn_scores.tsv",
            "genome_data/fission_yeasts/s_octosporus/train/s_octosporus_splice_cnn_scores.tsv",
            "genome_data/fission_yeasts/s_cryophilus/train/s_cryophilus_splice_cnn_scores.tsv"
        ],
        "test_scores": [
            "genome_data/fission_yeasts/s_pombe/test/s_pombe_splice_cnn_scores.tsv",
            "genome_data/fission_yeasts/s_japonicus/test/s_japonicus_splice_cnn_scores.tsv",
            "genome_data/fission_yeasts/s_octosporus/test/s_octosporus_splice_cnn_scores.tsv",
            "genome_data/fission_yeasts/s_cryophilus/test/s_cryophilus_splice_cnn_scores.tsv"
        ],
        "train_scores_minus": [
            "genome_data/fission_yeasts/s_pombe/train/s_pombe_splice_cnn_scores_minus.tsv",
            "genome_data/fission_yeasts/s_japonicus/train/s_japonicus_splice_cnn_scores_minus.tsv",
            "genome_data/fission_yeasts/s_octosporus/train/s_octosporus_splice_cnn_scores_minus.tsv",
            "genome_data/fission_yeasts/s_cryophilus/train/s_cryophilus_splice_cnn_scores_minus.tsv"
        ],
        "test_scores_minus": [
            "genome_data/fission_yeasts/s_pombe/test/s_pombe_splice_cnn_scores_minus.tsv",
            "genome_data/fission_yeasts/s_japonicus/test/s_japonicus_splice_cnn_scores_minus.tsv",
            "genome_data/fission_yeasts/s_octosporus/test/s_octosporus_splice_cnn_scores_minus.tsv",
            "genome_data/fission_yeasts/s_cryophilus/test/s_cryophilus_splice_cnn_scores_minus.tsv"
        ]
    },

    "start_cnn": {
        "model": "src/model/cnn/start/trained_models/fission_yeasts_start_cnn.pt",
        "start_scale": 1.0,
        "start_bias": -6.0,
        "train_scores": [
            "genome_data/fission_yeasts/s_pombe/train/s_pombe_start_cnn_scores.tsv",
            "genome_data/fission_yeasts/s_japonicus/train/s_japonicus_start_cnn_scores.tsv",
            "genome_data/fission_yeasts/s_octosporus/train/s_octosporus_start_cnn_scores.tsv",
            "genome_data/fission_yeasts/s_cryophilus/train/s_cryophilus_start_cnn_scores.tsv"
        ],
        "test_scores": [
            "genome_data/fission_yeasts/s_pombe/test/s_pombe_start_cnn_scores.tsv",
            "genome_data/fission_yeasts/s_japonicus/test/s_japonicus_start_cnn_scores.tsv",
            "genome_data/fission_yeasts/s_octosporus/test/s_octosporus_start_cnn_scores.tsv",
            "genome_data/fission_yeasts/s_cryophilus/test/s_cryophilus_start_cnn_scores.tsv"
        ],
        "train_scores_minus": [
            "genome_data/fission_yeasts/s_pombe/train/s_pombe_start_cnn_scores_minus.tsv",
            "genome_data/fission_yeasts/s_japonicus/train/s_japonicus_start_cnn_scores_minus.tsv",
            "genome_data/fission_yeasts/s_octosporus/train/s_octosporus_start_cnn_scores_minus.tsv",
            "genome_data/fission_yeasts/s_cryophilus/train/s_cryophilus_start_cnn_scores_minus.tsv"
        ],
        "test_scores_minus": [
            "genome_data/fission_yeasts/s_pombe/test/s_pombe_start_cnn_scores_minus.tsv",
            "genome_data/fission_yeasts/s_japonicus/test/s_japonicus_start_cnn_scores_minus.tsv",
            "genome_data/fission_yeasts/s_octosporus/test/s_octosporus_start_cnn_scores_minus.tsv",
            "genome_data/fission_yeasts/s_cryophilus/test/s_cryophilus_start_cnn_scores_minus.tsv"
        ]
    },

    "filters": {
        "min_first_cds_bp":     3,
        "min_last_cds_bp":      3,
        "min_intron_bp":        20,
        "require_3n_cds":       true,
        "include_minus_strand": true
    },

    "emissions": {
        "INTERGENIC":  { "type": "markov", "order": 1 },
        "INTRON":      { "type": "markov", "order": 1 },
        "EXON_FRAME":  { "type": "markov", "order": 5, "frame_tied": true },
        "DONOR":       { "type": "pssm", "window_left": 3,  "window_right": 6 },
        "ACCEPTOR":    { "type": "pssm", "window_left": 15, "window_right": 3 },
        "START_CODON": { "type": "deterministic" },
        "STOP_CODON":  { "type": "deterministic" }
    },

    "smoothing": {
        "transition_alpha": 0.02,
        "emission_alpha":   0.1
    }
}
